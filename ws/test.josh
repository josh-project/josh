:$label="test suite"
:$output="none"
deps = :[
    :#cargo-test[
        :$label="cargo test"
        :#image[:+images/dev-local/image]
        :$cache="rust"

        deps = :[
            :#fetch[:+ws/fetch]
        ]

        env = :[
            :$RUSTFLAGS="-D warnings"
        ]

        run = :[
            :$run.sh="set -e; cargo test --workspace --offline --locked"
            :exclude[
                ::ws/
                ::tests/
            ]
        ]
    ]
    :#fmt[
        :$label="cargo fmt"
        :#image[:+images/dev-local/image]

        run = :[
            :$run.sh="set -e; cargo fmt -- --check"
            :exclude[
                ::ws/
                ::tests/
            ]
        ]
    ]
    :#stable[
        :$label="stable tests"
        :#image[:+images/dev-local/image]

        deps = :[
            :#josh[:+ws/build-rust]
            :#build-go[:+ws/build-go]
        ]

        run = :[
            ::run.sh=ws/tests.sh
            ::run-tests.sh
            ::tests/:exclude[::tests/experimental/]
            ::scripts/
        ]
    ]
    :#experimental[
        :$label="experimental tests"
        :#image[:+images/dev-local/image]

        deps = :[
            :#josh[:+ws/build-rust]
            :#build-go[:+ws/build-go]
        ]

        env = :[
            :$JOSH_EXPERIMENTAL_FEATURES="1"
        ]

        run = :[
            ::run.sh=ws/tests.sh
            ::run-tests.sh
            ::tests/
            ::scripts/
        ]
    ]
]
