:$label="test suite"
:$output="none"
inputs = :[
    :#cargo-test[
        :$label="cargo test"
        :#image[:+images/dev-local]
        :$cache="rust"
        :$network="sidecar"
        :$cmd="cargo test --workspace --offline --locked"

        inputs = :[
            :#fetch[:+ws/fetch]
        ]

        env = :[
            :$RUSTFLAGS="-D warnings -Ctarget-feature=-crt-static"
        ]

        worktree = :[
            ::Cargo.toml
            ::Cargo.lock
            ::rust-toolchain.toml
            ::rustfmt.toml
            ::axum-cgi/
            ::axum-cgi-server/
            ::hyper-reverse-proxy/
            ::josh-*/**/*
            ::forges/
            ::deployment/
        ]
    ]
    :#fmt[
        :$label="cargo fmt"
        :#image[:+images/dev-local]
        :$cmd="cargo fmt -- --check"

        worktree = :[
            ::Cargo.toml
            ::Cargo.lock
            ::rust-toolchain.toml
            ::rustfmt.toml
            ::axum-cgi/
            ::axum-cgi-server/
            ::hyper-reverse-proxy/
            ::josh-*/**/*
            ::forges/
            ::deployment/
        ]
    ]
    :!ws/tests-per-category[::tests/]:exclude[:[::tests/]]
]
