:$output="none"
deps = :[
    :#cargo-test[
        :#image[:+images/dev-local/image]
        :$cache="cargo"

        deps = :[
            :#fetch[:+ws/fetch]
        ]

        run = :[
            ::run.sh=ws/cargo-test.sh
            :exclude[
                ::ws/
                ::tests/
            ]
        ]
    ]
    :#fmt[
        :#image[:+images/dev-local/image]

        run = :[
            :$run.sh="set -e; cargo fmt -- --check"
            :exclude[
                ::ws/
                ::tests/
            ]
        ]
    ]
    :#stable[
        :#image[:+images/dev-local/image]

        deps = :[
            :#josh[:+ws/build]
        ]

        run = :[
            ::run.sh=ws/tests.sh
            ::run-tests.sh
            ::tests/:exclude[::tests/experimental/]
            ::scripts/
        ]
    ]
    :#incubating[
        :#image[:+images/dev-local/image]

        deps = :[
            :#josh[
                :+ws/build
                env = :[
                    :$CARGO_BUILD_FEATURES="--features incubating"
                ]
            ]
        ]

        run = :[
            ::run.sh=ws/tests.sh
            ::run-tests.sh
            ::tests/
            ::scripts/
        ]
    ]
]
