:$label="test suite"
:$output="none"
inputs = :[
    :#cargo-test[
        :$label="cargo test"
        :#image[:+images/rust-dev-local]
        :$cache="sccache"
        :$cmd="cargo test --workspace --offline --locked && sccache --show-stats"

        :+sidecars

        inputs = :[
            :#fetch[:+ws/fetch]
        ]

        env = :[
            :$RUSTFLAGS="-D warnings -Ctarget-feature=-crt-static"
            :$CARGO_HOME="/fetch/cargo-cache"
        ]

        worktree = :[
            ::Cargo.toml
            ::Cargo.lock
            ::rust-toolchain.toml
            ::rustfmt.toml
            ::axum-cgi/
            ::axum-cgi-server/
            ::hyper-reverse-proxy/
            ::josh-*/**/*
            ::cq/
            ::forges/
            ::deployment/
        ]
    ]
    :#fmt[
        :$label="cargo fmt"
        :#image[:+images/rust-dev-local]
        :$cmd="cargo fmt -- --check"

        worktree = :[
            ::Cargo.toml
            ::Cargo.lock
            ::rust-toolchain.toml
            ::rustfmt.toml
            ::axum-cgi/
            ::axum-cgi-server/
            ::hyper-reverse-proxy/
            ::josh-*/**/*
            ::cq/
            ::forges/
            ::deployment/
        ]
    ]
    :!ws/tests-per-category[::tests/]:exclude[:[::tests/]]
]
