:$label="rust build"
:#image[:+images/rust-dev-local]
:$cache="sccache"

:+sidecars

inputs = :[
    :#fetch[:+ws/fetch]
]

env = :[
    ::JOSH_VERSION=VERSION_STRING
    :$CARGO_HOME="/fetch/cargo-cache"
]

worktree = :[
    ::run.sh=ws/build-rust.sh
    :+ws/patched-cargo
    ::Cargo.lock
    ::rust-toolchain.toml
    ::rustfmt.toml
    ::axum-cgi/
    ::axum-cgi-server/
    ::hyper-reverse-proxy/
    ::josh-*/**/*
    ::forges/
    ::deployment/
    ::static/
]
