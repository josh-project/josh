:$label="rust build"
:#image[:+images/dev-local]
:$cache="rust"

inputs = :[
    :#fetch[:+ws/fetch]
]

env = :[
    ::JOSH_VERSION=VERSION_STRING
]

worktree = :[
    ::run.sh=ws/build-rust.sh
    ::Cargo.toml
    ::Cargo.lock
    ::rust-toolchain.toml
    ::rustfmt.toml
    ::axum-cgi/
    ::axum-cgi-server/
    ::hyper-reverse-proxy/
    ::josh-*/**/*
    ::forges/
    ::deployment/
    ::static/
]
