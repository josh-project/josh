:$label="cargo fetch"
:#image[:+images/rust-dev-local]
:$network="host"

:$cmd="cargo fetch --locked"

env = :[
    :$CARGO_HOME="/out/cargo-cache"
]

worktree = :[
    :+ws/patched-cargo
    ::**/Cargo.toml
    ::**/Cargo.lock
    ::**/rust-toolchain.toml
    ::**/.cargo/
    :[
        ::**/lib.rs
        ::**/main.rs
        ::**/bin/
        ::**/build.rs
        ::**/benches/
        ::josh-core/benches/
        ::josh-search/benches/
    ]:replace("(?s).+":"")
]
